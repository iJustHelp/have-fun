@page "/waiting-room"
@layout RegisterLayout
@namespace HaveFun.Web

<PageTitle>Waiting Room</PageTitle>

<MudStack Spacing="4" Class="pa-4">
    @if (!IsSessionChecked)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Checking player session
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.h6">Hello, @DisplayName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Stay on this screen. The game will start when the host starts a round.
            </MudText>
        </MudPaper>
    }
</MudStack>
