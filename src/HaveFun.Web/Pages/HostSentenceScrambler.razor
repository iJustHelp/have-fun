@page "/host-sentence-scrambler"
@using HaveFun.Core
@namespace HaveFun.Web

<PageTitle>Host Sentence Scrambler</PageTitle>

@if (!IsSessionChecked)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        Checking role
    </MudAlert>
}
else if (ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
        @ErrorMessage
    </MudAlert>
    <MudButton Href="/"
               Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Home">
        Home
    </MudButton>
}
else
{
    <MudStack Spacing="4">
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h5">Sentence Scrambler Game</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    Rule: choose a file, start each sentence, and players arrange the shuffled words into the correct sentence.
                </MudText>
            </MudStack>
        </MudPaper>

        @if (FileLoadError is not null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @FileLoadError
            </MudAlert>
        }

        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="5">
                    <MudSelect T="string"
                               Label="Sentence file"
                               Variant="Variant.Outlined"
                               Value="@SelectedFileName"
                               ValueChanged="SelectSentenceFile"
                               Disabled="@(SentenceFiles.Count == 0 || IsRoundActive)">
                        @foreach (var file in SentenceFiles)
                        {
                            <MudSelectItem T="string" Value="@file.FileName">
                                @file.FileName
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudNumericField T="int"
                                     Label="Time"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     @bind-Value="TimeLimitInSeconds"
                                     Disabled="@IsRoundActive"
                                     Adornment="Adornment.End"
                                     AdornmentText="sec" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudPaper Class="pa-3 h-100" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.subtitle2">Sentence</MudText>
                        <MudText Typo="Typo.h6">
                            @(CurrentSentenceNumber == 0 ? "-" : CurrentSentenceNumber) of @(TotalSentenceCount == 0 ? "-" : TotalSentenceCount)
                        </MudText>
                        @if (IsRoundActive)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @RemainingTimeText remaining
                            </MudText>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="2" Class="d-flex align-end">
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Disabled="@(!CanStart)"
                               OnClick="StartRound">
                        Start
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (CurrentRound?.IsCompleted == true)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                Correct sentence: @CurrentRound.SentenceText
            </MudAlert>
        }

        @if (IsFileComplete)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                File complete.
            </MudAlert>
        }

        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Players</MudText>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                        @Players.Count player@(Players.Count == 1 ? string.Empty : "s")
                    </MudChip>
                </MudStack>

                @if (Players.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No players have registered yet.
                    </MudText>
                }
                else
                {
                    <MudTable T="HostPlayerResultRow"
                              Items="@PlayerResults"
                              Dense="true"
                              Hover="true"
                              Elevation="0">
                        <HeaderContent>
                            <MudTh>
                                <MudTableSortLabel T="HostPlayerResultRow" SortBy="@(row => row.PlayerName)">
                                    Player
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel T="HostPlayerResultRow" SortBy="@(row => row.TimeBeforeSubmitSeconds)">
                                    Time before submit
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>Submitted sentence</MudTh>
                            <MudTh>
                                <MudTableSortLabel T="HostPlayerResultRow" SortBy="@(row => row.Score ?? -1)">
                                    Score
                                </MudTableSortLabel>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Player">@context.PlayerName</MudTd>
                            <MudTd DataLabel="Time before submit">@FormatTimeBeforeSubmit(context.TimeBeforeSubmit)</MudTd>
                            <MudTd DataLabel="Submitted sentence">@(context.SubmittedSentence ?? string.Empty)</MudTd>
                            <MudTd DataLabel="Score">@FormatScore(context.Score, context.TotalScore)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        </MudPaper>
    </MudStack>
}
