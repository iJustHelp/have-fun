@page "/"
@page "/home"
@namespace HaveFun.Web

<PageTitle>Have Fun</PageTitle>

<MudStack Spacing="4">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="1" Style="min-height: 18rem;">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Color="Color.Secondary">
                        Please enter this URL in your browser address bar:
                    </MudText>
                    <MudText Typo="Typo.h5" Style="overflow-wrap: anywhere;">
                        @RegisterUrl
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="1" Style="min-height: 18rem;">
                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6" Color="Color.Secondary">
                        Or scan the QR code below with your mobile device:
                    </MudText>
                    @if (QrCodeDataUri is not null)
                    {
                        <img src="@QrCodeDataUri"
                             style="width: min(100%, 18rem); aspect-ratio: 1; image-rendering: pixelated;"
                             alt="QR code for the player registration URL" />
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                            @QrCodeError
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">Registered Players</MudText>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                    @Players.Count player@(Players.Count == 1 ? string.Empty : "s")
                </MudChip>
            </MudStack>

            @if (Players.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No players have registered yet.
                </MudText>
            }
            else
            {
                <MudTable T="PlayerSession"
                          Items="@Players"
                          Dense="true"
                          Hover="true"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Joined</MudTh>
                        <MudTh Style="text-align:right;">Remove</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                        <MudTd DataLabel="Joined">@context.JoinedAt.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="Remove" Style="text-align:right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => RemovePlayer(context.Id))"
                                           aria-label="@($"Remove {context.DisplayName}")" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>
</MudStack>
