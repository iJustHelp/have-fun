@page "/"
@namespace HaveFun.Web

<PageTitle>Have-Fun</PageTitle>

<MudStack Spacing="4">
    <MudPaper Class="pa-6" Elevation="0" Outlined="true">
        <MudStack Spacing="2">
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                Local server running
            </MudAlert>
            <MudText Typo="Typo.h3">Have-Fun</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                Host a browser game for friends on the same local network.
            </MudText>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Join Game</MudText>

                <form @onsubmit="JoinAsync" @onsubmit:preventDefault="true">
                    <MudStack Spacing="1">
                        <MudTextField @bind-Value="SubmittedName"
                                      Label="Name"
                                      Variant="Variant.Outlined"
                                      Error="@(ValidationError is not null)"
                                      ErrorText="@ValidationError"
                                      Immediate="true"
                                      AutoFocus="true" />
                        <MudButton ButtonType="ButtonType.Submit"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.Login"
                                   Disabled="@IsJoining">
                            Join
                        </MudButton>
                    </MudStack>
                </form>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Join URLs</MudText>

                <MudStack Spacing="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle2">Join from another device</MudText>
                        @if (LanUrl is null)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                LAN address was not detected. Check this computer's network connection.
                            </MudText>
                        }
                        else
                        {
                            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.body2"><code>@LanUrl</code></MudText>
                            </MudPaper>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        @SentenceCount predefined sentences are loaded. No database or cloud service is required.
    </MudAlert>
</MudStack>
