@page "/player-sentence-scrambler"
@layout RegisterLayout
@namespace HaveFun.Web

<PageTitle>Player Sentence Scrambler</PageTitle>

<MudStack Spacing="4" Class="pa-4">
    @if (!IsSessionChecked)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Checking player session
        </MudAlert>
    }
    else if (ErrorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @ErrorMessage
        </MudAlert>
        <MudButton Href="/register"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Login">
            Register
        </MudButton>
    }
    else if (CurrentRound is not null)
    {
        <PlayerGameBoard Title="Sentence Scrambler Game"
                         Rules="Rule: rearrange the available words to make a correct sentence."
                         AvailableTiles="@(PlayerRoundState?.AvailableTiles ?? [])"
                         SelectedTiles="@(PlayerRoundState?.SelectedTiles ?? [])"
                         IsSubmitted="@(PlayerRoundState?.IsSubmitted == true)"
                         SubmittedText="@PlayerRoundState?.SubmittedSentence"
                         SpentTime="@PlayerRoundState?.SpentTime"
                         RemainingTimeText="@RemainingTimeText"
                         CanSubmit="@CanSubmit"
                         OnSelectItem="SelectWord"
                         OnReturnItem="ReturnWord"
                         OnSubmit="SubmitRound" />
    }
</MudStack>
