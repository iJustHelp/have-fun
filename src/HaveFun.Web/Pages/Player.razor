@page "/player"
@namespace HaveFun.Web

<PageTitle>Player</PageTitle>

<MudStack Spacing="4">
    @if (!IsSessionChecked)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Checking player session
        </MudAlert>
    }
    else if (ErrorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @ErrorMessage
        </MudAlert>
        <MudButton Href="/"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Home">
            Back to join
        </MudButton>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h3">@DisplayName</MudText>
                @if (CurrentRound is null)
                {
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                        Waiting for the master to start a round.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                        Round started
                    </MudText>
                }
            </MudStack>
        </MudPaper>

        @if (CurrentRound is null)
        {
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6">Waiting Room</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Stay on this screen. The round will appear here when the master starts it.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-4">Round Status</MudText>
                        <MudChip T="string" Color="@RoundStatusColor" Variant="Variant.Outlined">
                            @CurrentRound.Status
                        </MudChip>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">
                            @CurrentRound.TimeLimitInSeconds seconds
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-4">Timer</MudText>
                        <MudText Typo="Typo.h4">@RemainingTimeText</MudText>
                        @if (IsTimerExpired)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Error">
                                Time is up
                            </MudText>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-4">Words</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @CurrentRound.ShuffledWords.Count words ready
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Shuffled Words</MudText>
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    @foreach (var word in CurrentRound.ShuffledWords)
                    {
                        <MudChip T="string"
                                 Color="Color.Primary"
                                 Variant="Variant.Outlined">
                            @word
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }
    }
</MudStack>
