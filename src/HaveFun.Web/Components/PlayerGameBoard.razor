@namespace HaveFun.Web

<MudPaper Class="pa-6" Elevation="0" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            @Rules
        </MudText>
    </MudStack>
</MudPaper>

<MudItem>
    <MudChip T="string"
             Color="Color.Secondary"
             Variant="Variant.Outlined"
             Icon="@Icons.Material.Filled.Timer">
        @RemainingTimeText remaining
    </MudChip>
</MudItem>

<MudPaper Class="pa-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6" Class="mb-4">Your Sentence</MudText>
    @if (PlayerRoundState is null || PlayerRoundState.CollectedWords.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Click words below to build your sentence.
        </MudText>
    }
    else
    {
        <MudStack Row="true" Spacing="2" Class="flex-wrap">
            @foreach (var word in PlayerRoundState.CollectedWords)
            {
                <MudButton Color="Color.Secondary"
                           Variant="Variant.Outlined"
                           Style="text-transform: none;"
                           OnClick="@(() => ReturnWordAsync(word.Id))">
                    @word.Text
                </MudButton>
            }
        </MudStack>
    }
</MudPaper>

@if (PlayerRoundState?.IsSubmitted == true)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
        Submitted: @PlayerRoundState.SubmittedSentence
        @if (PlayerRoundState.SpentTime is not null)
        {
            <span> (@FormatSpentTime(PlayerRoundState.SpentTime.Value))</span>
        }
    </MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-4">Available Words</MudText>
        @if (PlayerRoundState is null || PlayerRoundState.AvailableWords.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                All words are selected. Submit when ready.
            </MudText>
        }
        else
        {
            <MudStack Row="true" Spacing="2" Class="flex-wrap">
                @foreach (var word in PlayerRoundState.AvailableWords)
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Outlined"
                               Style="text-transform: none;"
                               OnClick="@(() => SelectWordAsync(word.Id))">
                        @word.Text
                    </MudButton>
                }
            </MudStack>
        }
    </MudPaper>

    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Check"
               Disabled="@(!CanSubmit)"
               OnClick="SubmitAsync">
        Submit
    </MudButton>
}

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Rules { get; set; } = string.Empty;

    [Parameter]
    public PlayerRoundState? PlayerRoundState { get; set; }

    [Parameter]
    public string RemainingTimeText { get; set; } = string.Empty;

    [Parameter]
    public bool CanSubmit { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelectWord { get; set; }

    [Parameter]
    public EventCallback<Guid> OnReturnWord { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }

    private Task SelectWordAsync(Guid wordId)
    {
        return OnSelectWord.InvokeAsync(wordId);
    }

    private Task ReturnWordAsync(Guid wordId)
    {
        return OnReturnWord.InvokeAsync(wordId);
    }

    private Task SubmitAsync()
    {
        return OnSubmit.InvokeAsync();
    }

    private static string FormatSpentTime(TimeSpan spentTime)
    {
        return $"{(int)spentTime.TotalMinutes:00}:{spentTime.Seconds:00}";
    }
}
