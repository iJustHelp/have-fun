@namespace HaveFun.Web

<MudPaper Class="pa-6" Elevation="0" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h5">@Title</MudText>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            @Rules
        </MudText>
    </MudStack>
</MudPaper>

<MudItem>
    <MudChip T="string"
             Color="Color.Secondary"
             Variant="Variant.Outlined"
             Icon="@Icons.Material.Filled.Timer">
        @RemainingTimeText remaining
    </MudChip>
</MudItem>

<MudPaper Class="pa-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6" Class="mb-4">Your Sentence</MudText>
    @if (_selectedTiles.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Click words below to build your sentence.
        </MudText>
    }
    else
    {
        <MudStack Row="true" Spacing="2" Class="flex-wrap">
            @foreach (var word in _selectedTiles)
            {
                <MudButton Color="Color.Secondary"
                           Variant="Variant.Outlined"
                           Style="text-transform: none;"
                           OnClick="@(() => ReturnTile(word.Id))">
                    @word.Text
                </MudButton>
            }
        </MudStack>
    }
</MudPaper>

@if (IsSubmitted)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
        Submitted: @SubmittedText
        @if (SpentTime is not null)
        {
            <span> (@FormatSpentTime(SpentTime.Value))</span>
        }
    </MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-4">Available Words</MudText>
        @if (_availableTiles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                All words are selected. Submit when ready.
            </MudText>
        }
        else
        {
            <MudStack Row="true" Spacing="2" Class="flex-wrap">
                @foreach (var word in _availableTiles)
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Outlined"
                               Style="text-transform: none;"
                               OnClick="@(() => SelectTile(word.Id))">
                        @word.Text
                    </MudButton>
                }
            </MudStack>
        }
    </MudPaper>

    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Check"
               Disabled="@(!CanSubmitDraft)"
               OnClick="SubmitAsync">
        Submit
    </MudButton>
}
